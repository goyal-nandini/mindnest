<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MindNest — Create account</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
</head>
<body>
  <div class="mn-auth-page">
    <div class="mn-auth-card">
      <div class="mn-auth-logo">
        <div class="mn-auth-logo-text">🪴 MindNest</div>
        <div class="mn-auth-logo-sub">Your safe space to write and reflect</div>
      </div>
      <h2 class="mn-auth-title">Create your journal</h2>
      <p class="mn-auth-sub">Free forever. No credit card needed.</p>
      <form action="/register" method="POST">
        <div class="mn-form-group">
          <label class="mn-label">Your name</label>
          <input type="text" name="name" class="mn-input" placeholder="What should we call you?" required />
        </div>
        <div class="mn-form-group">
          <label class="mn-label">Email</label>
          <input type="email" name="username" class="mn-input" placeholder="you@example.com" required />
        </div>
        <div class="mn-form-group">
          <label class="mn-label">Password</label>
          <div class="mn-input-wrap">
            <input type="password" name="password" id="passwordInput" 
                  class="mn-input" placeholder="••••••••" required />
            <button type="button" class="mn-eye-btn" id="eyeBtn" 
                    onclick="togglePassword()">
              <i class="ti ti-eye" id="eyeIcon"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn-sage" style="width:100%; margin-top:0.5rem;">Create account</button>
      </form>
      <div class="mn-divider">or continue with</div>
      <a href="/auth/google" class="mn-google-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Continue with Google
      </a>
      <div class="mn-auth-footer">
        Already have an account? <a href="/login">Sign in</a>
      </div>
    </div>
  </div>
  <script>
  function togglePassword() {
    const input = document.getElementById('passwordInput');
    const icon = document.getElementById('eyeIcon');
    if (input.type === 'password') {
      input.type = 'text';
      icon.className = 'ti ti-eye-off';
    } else {
      input.type = 'password';
      icon.className = 'ti ti-eye';
    }
  }
</script>
</body>
</html>