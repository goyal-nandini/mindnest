  <!-- COUNTER SECTION -->
<section class="mn-counter-section">
  <div class="mn-counter-grid">
    <div class="mn-counter-item">
      <div class="mn-counter-num" data-target="<%= journalsCreated %>">0</div>
      <div class="mn-counter-label">Journals created</div>
    </div>
    <div class="mn-counter-item">
      <div class="mn-counter-num" data-target="<%= entriesWritten %>">0</div>
      <div class="mn-counter-label">Entries written</div>
    </div>
    <div class="mn-counter-item">
      <div class="mn-counter-num" data-target="<%= happyWriters %>">0</div>
      <div class="mn-counter-label">Happy writers</div>
    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('.mn-counter-num');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target;
      const target = parseInt(el.dataset.target);
      let current = 0;
      const step = Math.ceil(target / 60);
      const timer = setInterval(() => {
        current = Math.min(current + step, target);
        el.textContent = current.toLocaleString();
        if (current >= target) clearInterval(timer);
      }, 25);
      observer.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(c => observer.observe(c));
</script>

