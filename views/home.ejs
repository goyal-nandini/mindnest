    </div>
    <div class="mn-feature-item">
      <div class="mn-feature-icon"><i class="ti ti-device-mobile" aria-hidden="true"></i></div>
      <div class="mn-feature-title">Anywhere, anytime</div>
      <div class="mn-feature-desc">Access your journal from any device, any time.</div>
    </div>
